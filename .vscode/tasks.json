{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync skills on open",
      "type": "shell",
      "command": "sh",
      "args": [
        "-c",
        "if [ -f \"${workspaceFolder}/bin/sync-skills.sh\" ]; then \"${workspaceFolder}/bin/sync-skills.sh\" --pull; elif [ -f \"${workspaceFolder}/automotive-pm/bin/sync-skills.sh\" ]; then \"${workspaceFolder}/automotive-pm/bin/sync-skills.sh\" --pull \"${workspaceFolder}\"; fi"
      ],
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent" }
    }
  ]
}
